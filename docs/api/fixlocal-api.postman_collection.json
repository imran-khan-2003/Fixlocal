            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"phone\": \"+911234567890\",\n  \"role\": \"USER\",\n  \"workingCity\": \"Bengaluru\"\n}"
